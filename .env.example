# --- Database (Neon Postgres) ---
# Use the POOLED connection string (host contains "-pooler").
# Leave unset to run the app on rich demo data with zero configuration.
DATABASE_URL=postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/affilaite?sslmode=require

# --- Auth (Auth.js v5) ---
AUTH_SECRET=generate-with-npx-auth-secret
NEXTAUTH_URL=https://your-app.onrender.com
ADMIN_EMAIL=bu@brecx.com
ADMIN_PASSWORD=change-me

# --- Shopify (custom app on your own store) ---
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxx
SHOPIFY_API_SECRET=xxx           # for webhook HMAC verification
SHOPIFY_API_VERSION=2025-07

# --- PayPal Payouts ---
PAYPAL_CLIENT_ID=xxx
PAYPAL_CLIENT_SECRET=xxx
PAYPAL_BASE=https://api-m.sandbox.paypal.com   # api-m.paypal.com for live

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx
EMAIL_FROM=Affilaite <affiliates@yourbrand.com>

# --- App ---
APP_URL=https://your-app.onrender.com
CRON_SECRET=generate-a-long-random-string
